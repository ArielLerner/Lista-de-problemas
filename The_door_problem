#include <bits/stdc++.h>
#define forr(i,a,b) for(int i = (a); i < (b); i++)
#define forn(i,n) forr(i,0,n)
#define dforr(i,a,b) for(int i = (b-1); i >= (a); i--)
#define dforn(i,n) dforr(i,0,n)
#define all(x) x.begin(),x.end()
#define pb push_back
#define sz(i) i.size()
using namespace std;
using ll = long long int;
using par = pair<int,int>;
vector<vector<int>> sw;
vector<vector<int>> ady;
int n,m;
int inv(int x){
    return (x + m) % (2 * m);
}
void conectar(int a, int b){
    ady[a].pb(b);
    ady[b].pb(a);
}
void dfs(int i, vector<int> &comp , int c){
    comp[i] = c;
    for(int h: ady[i]){
        if(comp[h] == -1){
            dfs(h,comp,c);
        }
    }
}
int main(){
    //freopen("C:/Users/Gamer/OneDrive/Escritorio/OIA/codeforces/stdin.txt","r",stdin);
    cin >> n >> m;
    vector<bool> open(n);
    forn(i,n){
        int x; cin >> x;
        open[i] = x;
    }
    sw.resize(n);
    forn(i,m){
        int q; cin >> q;
        forn(i2,q){
            int door; cin >> door;
            sw[door-1].pb(i);
        }
    }
    // creo el grafo de implicancias con  i, inv i
    ady.resize(2 * m); 
    forn(i,sz(sw)){
        int s1 = sw[i][0];
        int s2 = sw[i][1];
        if(open[i]){
            conectar(s1,s2);
            conectar(inv(s1),inv(s2));
        }
        else{ // si esta cerrada
            conectar(s1,inv(s2));
            conectar(s2,inv(s1));
        }
    }
    // ya arme el grafo
    // busco los comp. conexos para saber si a y !a estan en el mismo -> no se puede en este caso
    vector<int> comp(2 * m,-1);
    forn(i,2 * m){
        if(comp[i] != -1){continue;}
        dfs(i,comp,i);
    }
    bool isAns = true;
    forn(i,m){
        if(comp[i] == comp[inv(i)]){
            isAns = false;
        }
    }
    if(isAns){
        cout << "YES" << endl;
    }
    else{
        cout << "NO" << endl;
    }
}
